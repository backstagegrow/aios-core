# AIOS Framework Environment Variables (Template)
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ==========================================
# 🧠 AI Providers (CRITICAL)
# Tokens for inference models. All agents delegate execution here.
# ==========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_key_here

# ==========================================
# 🛡️ Supabase / Observability / RAG DB (CRITICAL)
# Supabase keys to manage Vector Store, agent's memory, logs and metrics.
# NEVER share the SERVICE_ROLE_KEY (grants Admin bypass/elevated access).
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ==========================================
# 📈 Framework Ops & ClickUp Project Management
# Settings for task execution and orchestration external tools.
# ==========================================
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_TEAM_ID=90132645314
CLICKUP_MCP_LICENSE_KEY=your_clickup_mcp_license_key_here

# ==========================================
# 📱 Meta Ads API & Social Media (HIGH)
# Tokens for Paid Media and Growth Squads (meta_ads_optimizer).
# ==========================================
META_ADS_ACCESS_TOKEN=your_meta_token_here
META_ADS_ACCESS_TOKEN_FILE=
META_ADS_ACCESS_TOKEN_COMMAND=
META_AD_ACCOUNT_ID=your_ad_account_id_here
META_GRAPH_API_VERSION=v19.0

# ==========================================
# 🎨 Design & Visual Engineering
# Used by ux_ui_page_designer, design_system_curator
# ==========================================
CANVA_API_KEY=your_canva_api_key_here

# ==========================================
# ⚙️ DevOps, CI/CD, and Fallbacks
# Tokens for pipeline validation, observability triggers and debug modes.
# ==========================================
GITHUB_TOKEN=your_github_token_here
AIOS_DEBUG=false
AIOS_DEFAULT_MODEL=claude-3-5-sonnet-20241022
AIOS_FALLBACK_MODEL=claude-3-5-haiku-20241022
NODE_ENV=development

# ==========================================
# 🎨 Design Post Generator — ComfyUI
# Self-hosted ComfyUI REST API endpoint
# Default: http://127.0.0.1:8188 (local)
# ==========================================
COMFYUI_HOST=http://127.0.0.1:8188
# ComfyUI model checkpoint filename (must match what's in your ComfyUI/models/checkpoints/)
COMFYUI_MODEL=sd_xl_base_1.0.safetensors
# Directory where ComfyUI saves output images (used for asset download)
COMFYUI_OUTPUT_DIR=./packages/brand-engine/design-post/output

# ==========================================
# 🎨 Hugging Face (Design Post — Image Generation via FLUX)
# Obtenha em: https://huggingface.co/settings/tokens
# ==========================================
HF_TOKEN=your_huggingface_token_here

# ==========================================
# 📧 Email Automation (Brevo)
# Configure em: https://app.brevo.com/settings/keys/api
# ==========================================
BREVO_API_KEY=your_brevo_api_key_here
