{
  "attachmentFolderPath": "attachments",
  "baseFontSize": 16,
  "baseFontSizeAction": false,
  "boldMdcursor": false,
  "clipboardManager": true,
  "cssTheme": "",
  "currentTheme": "obsidian",
  "dailyNotesFormat": "YYYY-MM-DD",
  "defaultViewMode": "preview",
  "foldHeading": false,
  "foldIndent": false,
  "lineNumbers": false,
  "markdown": {
    "maxNestingLevel": 20
  },
  "mobileSyncInterval": 60,
  "nativeMenus": true,
  "newFileLocation": "root",
  "newFileFolderPath": "research",
  "newLinkFormat": "shortest",
  "obsidianCacheSize": 10,
  "pdfExportSettings": {
    "includeCSSTheme": true,
    "pageSize": "letter",
    "margin": "1in",
    "downscaleImageBelow": 1920
