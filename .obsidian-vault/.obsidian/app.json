  "spellcheckLanguages": [
    "en",
    "pt"
  ],
  "strictLineBreaks": false,
  "strictPropertyLineBreaks": false,
  "tabSize": 2,
  "trashInLogical": true,
  "useMarkdownLinks": true,
  "useTab": true,
  "useThemeButtonBorders": false,
  "vimMode": false,
  "autoRunCommand": false,
  "autosaveInterval": 25000,
  "autosaveIntervalSeconds": 25
