{
    "color": {
        "core": {
            "amber": "#C9A24A",
            "amber-light": "#D4AE5A",
            "amber-dark": "#B28C39",
            "background-dark": "#0A0A0A",
            "foreground-light": "#FAF9F6",
            "surface": "#141414",
            "surface-light": "#1E1E1E",
            "gray-500": "#9CA3AF",
            "gray-800": "#1F2937",
            "success": "#22C55E",
            "warning": "#F59E0B",
            "error": "#EF4444",
            "white": "#FFFFFF",
            "black": "#000000"
        },
        "semantic": {
            "text-primary": "var(--foreground-light)",
            "text-secondary": "var(--gray-500)",
            "text-muted": "var(--gray-800)",
            "text-on-dark": "var(--white)",
            "text-on-brand": "var(--black)",
            "surface-page": "var(--background-dark)",
            "surface-section": "var(--surface)",
            "surface-card": "var(--surface-light)",
            "surface-subtle": "rgba(255, 255, 255, 0.05)",
            "surface-elevated": "var(--surface-light)",
            "action-primary": "var(--amber)",
            "action-primary-hover": "var(--amber-light)",
            "action-primary-active": "var(--amber-dark)",
            "action-secondary": "transparent",
            "action-strong": "var(--white)",
            "action-strong-hover": "var(--gray-500)",
            "border-default": "var(--surface-light)",
            "border-subtle": "rgba(255, 255, 255, 0.1)",
            "border-focus": "var(--amber)",
            "status-success": "var(--success)",
            "status-warning": "var(--warning)",
            "status-error": "var(--error)",
            "overlay-backdrop": "rgba(0, 0, 0, 0.8)",
            "overlay-modal": "var(--surface)",
            "overlay-popover": "var(--surface-light)"
        }
    },
    "spacing": {
        "space-1": "0.25rem",
        "space-2": "0.5rem",
        "space-3": "0.75rem",
        "space-4": "1rem",
        "space-6": "1.5rem",
        "space-8": "2rem",
        "space-12": "3rem",
        "space-16": "4rem",
        "space-20": "5rem"
    },
    "radius": {
        "radius-sm": "4px",
        "radius-md": "12px",
        "radius-lg": "16px",
        "radius-xl": "0.75rem",
        "radius-2xl": "1rem",
        "radius-full": "9999px"
    },
    "typography": {
        "fontFamily": {
            "heading": "'Inter', system-ui, sans-serif",
            "subheading": "'Inter', system-ui, sans-serif",
            "body": "'Inter', system-ui, sans-serif",
            "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
        },
        "size": {
            "text-xs": "0.75rem",
            "text-sm": "0.875rem",
            "text-base": "1rem",
            "text-lg": "1.125rem",
            "text-xl": "1.25rem",
            "text-2xl": "1.5rem",
            "text-3xl": "1.875rem",
            "text-4xl": "2.25rem",
            "text-5xl": "3rem",
            "text-6xl": "3.75rem"
        },
        "weight": {
            "font-normal": "400",
            "font-medium": "500",
            "font-semibold": "600",
            "font-bold": "700",
            "font-black": "900"
        },
        "lineHeight": {
            "leading-none": "1",
            "leading-tight": "1.2",
            "leading-snug": "1.375",
            "leading-normal": "1.5",
            "leading-relaxed": "1.75"
        },
        "letterSpacing": {
            "tracking-tighter": "-0.05em",
            "tracking-tight": "-0.025em",
            "tracking-normal": "0",
            "tracking-wide": "0.025em",
            "tracking-widest": "0.1em"
        },
        "scale": {
            "heading-xl": {
                "size": "var(--text-6xl)",
                "weight": "var(--font-black)",
                "leading": "var(--leading-none)",
                "tracking": "var(--tracking-tighter)"
            },
            "heading-lg": {
                "size": "var(--text-4xl)",
                "weight": "var(--font-bold)",
                "leading": "var(--leading-tight)",
                "tracking": "var(--tracking-tight)"
            },
            "heading-md": {
                "size": "var(--text-2xl)",
                "weight": "var(--font-semibold)",
                "leading": "var(--leading-snug)",
                "tracking": "var(--tracking-tight)"
            },
            "subheading": {
                "size": "var(--text-lg)",
                "weight": "var(--font-medium)",
                "leading": "var(--leading-normal)",
                "tracking": "var(--tracking-normal)"
            },
            "body-lg": {
                "size": "var(--text-lg)",
                "weight": "var(--font-normal)",
                "leading": "var(--leading-relaxed)",
                "tracking": "var(--tracking-normal)"
            },
            "body-md": {
                "size": "var(--text-base)",
                "weight": "var(--font-normal)",
                "leading": "var(--leading-normal)",
                "tracking": "var(--tracking-normal)"
            },
            "body-sm": {
                "size": "var(--text-sm)",
                "weight": "var(--font-normal)",
                "leading": "var(--leading-normal)",
                "tracking": "var(--tracking-normal)"
            },
            "caption": {
                "size": "var(--text-xs)",
                "weight": "var(--font-normal)",
                "leading": "var(--leading-tight)",
                "tracking": "var(--tracking-wide)"
            },
            "label": {
                "size": "var(--text-xs)",
                "weight": "var(--font-bold)",
                "leading": "var(--leading-none)",
                "tracking": "var(--tracking-widest)"
            }
        }
    },
    "shadow": {
        "shadow-sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "shadow-md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
        "shadow-lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
        "shadow-card": "0 8px 30px rgba(0, 0, 0, 0.12)",
        "shadow-card-hover": "0 14px 40px rgba(0, 0, 0, 0.16)",
        "shadow-button-primary": "0 8px 32px rgba(201, 162, 74, 0.3)"
    },
    "motion": {
        "motion-fast": "150ms",
        "motion-normal": "300ms",
        "motion-slow": "500ms"
    }
}